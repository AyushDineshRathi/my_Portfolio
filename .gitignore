# ================================
# Root Gitignore (Backend + Frontend)
# ================================

# --------------------
# Node Modules
# --------------------
node_modules/
**/node_modules/

# --------------------
# Environment Variables
# --------------------
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
backend/.env

# --------------------
# Build Output
# --------------------
dist/
build/
frontend/dist/
backend/dist/
frontend/.vite/
.vite/

# Vite cache
frontend/.vite/
.vite/

# --------------------
# Logs
# --------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# --------------------
# Editor folders/files
# --------------------
.vscode/
.idea/
*.swp

# --------------------
# OS-generated files
# --------------------
.DS_Store
Thumbs.db

# --------------------
# Misc
# --------------------
*.local
*.cache
.cache/
.tmp/
temp/
*.tmp
